NODE_ENV=development
PORT=3000
APP_NAME=NewspaperGeneratorBackend
API_PREFIX=api/v1
DATABASE_URL=postgres://newspaper:newspaper@localhost:5432/newspaper_generator
DATABASE_SSL=false
JWT_SECRET=change-me-local-dev-only-use-secrets-manager-in-prod
JWT_EXPIRES_IN=15m
BCRYPT_ROUNDS=10
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Redis cache. If REDIS_URL is missing, the API still starts but cache remains disabled.
REDIS_URL=redis://localhost:6379
CACHE_PREFIX=newspaper
CACHE_TTL_SECONDS=300

# Backup job to a second Neon project/database.
# Never point this to the same DATABASE_URL. Store the real value in CI/CD secrets.
NEON_BACKUP_DATABASE_URL=postgres://backup_user:backup_password@backup-neon-host.neon.tech/newspaper_backup?sslmode=require
BACKUP_FILE_DIR=./backups
BACKUP_KEEP_LOCAL_FILES=false
NEON_BACKUP_DROP_TARGET_BEFORE_RESTORE=false

# Production hardening
JWT_REFRESH_EXPIRES_IN_DAYS=30
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX=8
RATE_LIMIT_WRITE_MAX=80
RATE_LIMIT_READ_MAX=300

# Event worker
WORKER_EVENTS_BATCH_SIZE=25
WORKER_EVENTS_INTERVAL_MS=5000
WORKER_LOCK_TTL_SECONDS=45
