{
  "name": "newspaper-generator-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend NestJS event-driven base para periódico digital premium.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20 <27"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all",
    "db:undo-seed": "sequelize-cli db:seed:undo:all",
    "db:undo": "sequelize-cli db:migrate:undo:all",
    "db:reset": "npm run db:undo && npm run db:migrate && npm run db:seed",
    "typecheck": "tsc --noEmit",
    "test:smoke": "npm run test:smoke:db",
    "test:smoke:db": "tsx scripts/smoke.ts",
    "test:smoke:http": "tsx scripts/smoke-http.ts",
    "test:smoke:all": "npm run test:smoke:db && npm run test:smoke:http",
    "backup:neon": "tsx scripts/backup-to-neon.ts",
    "start:worker:events": "tsx scripts/workers/events-worker.ts",
    "start:worker:events:once": "tsx scripts/workers/events-worker.ts --once",
    "test:unit": "tsx --test test/unit/**/*.test.ts",
    "test:contracts": "tsx --test test/contracts/**/*.test.ts",
    "test:security": "tsx scripts/security-smoke.ts",
    "test:all": "npm run db:validate && npm run postman:validate && npm audit --audit-level=moderate && npm run typecheck && npm run build && npm run test:unit && npm run test:contracts && npm run test:smoke:db && npm run test:smoke:http && npm run test:security && npm run start:worker:events:once",
    "db:validate": "tsx scripts/validate-db.ts",
    "postman:validate": "python3 -m json.tool postman/NewspaperGeneratorBackend.postman_collection.json >/dev/null && python3 -m json.tool postman/NewspaperGeneratorBackend.local.postman_environment.json >/dev/null"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.5",
    "supertest": "^7.2.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "sequelize-cli": "^6.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "multer": "^2.2.0",
    "js-yaml": "^5.2.0",
    "uuid": "^11.1.1",
    "glob": "^13.0.6"
  }
}
